# ─────────────────────────────────────────────────────────────
# La Flor Blanca — Labor Alert System  |  Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to ".env" for local testing.
# On Railway, add these as Variables in the project dashboard.
# NEVER commit your real .env file to GitHub.
# ─────────────────────────────────────────────────────────────

# Square (get from developer.squareup.com → your app → Production)
SQUARE_ACCESS_TOKEN=your_square_production_access_token_here
SQUARE_LOCATION_ID=your_square_location_id_here

# SendGrid email alerts (required — all three must be set)
# Get API key: app.sendgrid.com → Settings → API Keys → Create API Key (Mail Send permission)
# ALERT_EMAIL_FROM must be a verified Sender Identity in your SendGrid account
SENDGRID_API_KEY=your_sendgrid_api_key_here
ALERT_EMAIL_FROM=business-alerts@yourdomain.com
ALERT_EMAIL_TO=owner@example.com,manager@example.com

# Anthropic / Claude AI advisor (optional — omit to disable AI section in alerts)
# Get API key: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# Timezone — find yours at: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# Examples: America/Chicago  America/New_York  America/Los_Angeles  America/Denver
TIMEZONE=America/Los_Angeles

# Alert settings (optional — defaults shown)
LABOR_THRESHOLD_PCT=33       # Send alert when labor % exceeds this number
ESCALATION_HOURS=2           # Send escalation alert after this many hours over threshold
